---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const certs = (await getCollection("certificates")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout title="Certificates">
  <div class="max-w-3xl mx-auto text-left">
    <h1 class="page-header text-3xl md:text-4xl mb-8">Certificates</h1>

    <ul class="list-none p-0 mt-4 pl-0">
      {
        certs.map(({ data }) => (
          <li class="mb-8">
            <span class="page-header text-xl block mb-3">{data.category}</span>
            <ul class="list-none pl-0 space-y-2">
              {data.certificates.map((cert: { name: string; link: string }) => (
                <li class="cert-item">
                  <a
                    target="_blank"
                    href={cert.link}
                    class="cert-link hover:text-accent dark:hover:text-accent-dark"
                  >
                    {cert.name}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      class="cert-icon inline-block align-top"
                    >
                      <path d="M15 1.31a.5.5 0 0 0-.461-.309h-4a.5.5 0 0 0 0 1h2.79l-7.15 7.15a.5.5 0 0 0 .707.707l7.15-7.15v2.79a.5.5 0 0 0 1 0v-4a.5.5 0 0 0-.038-.188z" />
                      <path d="M3.5 3A2.5 2.5 0 0 0 1 5.5v7A2.5 2.5 0 0 0 3.5 15h7a2.5 2.5 0 0 0 2.5-2.5v-5a.5.5 0 0 0-1 0v5a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 2 12.5v-7A1.5 1.5 0 0 1 3.5 4h5a.5.5 0 0 00 0-1z" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>

<style>
  .cert-item {
    position: relative;
    padding-left: 1.5em;
  }
  .cert-item::before {
    content: "○";
    position: absolute;
    left: 0;
    top: 0.3em;
    font-size: 0.75em;
    color: var(--color-text);
  }
  .dark .cert-item::before {
    color: var(--color-text-dark);
  }
  .cert-link {
    color: var(--color-text);
    text-decoration: none;
  }
  .dark .cert-link {
    color: var(--color-text-dark);
  }
  .cert-icon {
    margin-left: 1px;
    margin-top: 0.2em;
    opacity: 0.8;
    fill: var(--color-text);
  }
  .cert-link:hover .cert-icon {
    opacity: 1;
  }
  .dark .cert-icon {
    fill: var(--color-text-dark);
  }
</style>
