---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Flourish">
  <h1 class="font-bebas text-4xl mb-8">Flourish</h1>
  <div class="flex flex-col md:flex-row gap-4 w-full">
    <div class="w-full flourish-embed flourish-chart" data-src="visualisation/9654060">
      <script src="https://public.flourish.studio/resources/embed.js"></script>
    </div>
    <div class="w-full flourish-embed flourish-chart" data-src="visualisation/9449369">
      <script src="https://public.flourish.studio/resources/embed.js"></script>
    </div>
  </div>
</Layout>
