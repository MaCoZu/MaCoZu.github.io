---
import { twMerge } from 'tailwind-merge';

const { id, className = '' } = Astro.props;

const base =
  'prose prose-stone text-xl leading-loose max-w-prose dark:prose-invert prose-p:text-pretty prose-img:rounded-xl';

const merged = twMerge(base, className);
---

<article id={id} class={merged}>
  <slot />
</article>