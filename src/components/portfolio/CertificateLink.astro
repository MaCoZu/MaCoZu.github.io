---
interface Props {
  name: string;
  link: string;
}

const { name, link } = Astro.props;
---

<li class="!my-2">
  <a
    target="_blank"
    href={link}
    class="hover:text-link dark:hover:text-link-dark inline-flex items-center gap-2 no-underline"
    style="color: var(--color-text)"
  >
    {name}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="currentColor"
      class="inline-block ml-1 relative -top-[0.15em] opacity-80 hover:opacity-100 shrink-0 transition-opacity duration-200"
    >
      <path
        d="M15 1.31a.5.5 0 0 0-.461-.309h-4a.5.5 0 0 0 0 1h2.79l-7.15 7.15a.5.5 0 0 0 .707.707l7.15-7.15v2.79a.5.5 0 0 0 1 0v-4a.5.5 0 0 0-.038-.188z"
      ></path>
      <path
        d="M3.5 3A2.5 2.5 0 0 0 1 5.5v7A2.5 2.5 0 0 0 3.5 15h7a2.5 2.5 0 0 0 2.5-2.5v-5a.5.5 0 0 0-1 0v5a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 2 12.5v-7A1.5 1.5 0 0 1 3.5 4h5a.5.5 0 0 0 0-1z"
      ></path>
    </svg>
  </a>
</li>
