---
import { Image } from "astro:assets";
const {
  href,
  imagePath,
  imageAlt,
  heading,
  text,
  objectFit = "object-cover",
} = Astro.props;
---

<div class="w-full dark:bg-bg-dark">
  <a href={href}>
    <div class="relative w-full aspect-square overflow-hidden">
      <Image
        src={imagePath}
        alt={imageAlt}
        inferSize
        class={`w-full h-full ${objectFit} p-3`}
      />
    </div>
    <div class="mt-3 pb-3 px-3">
      <h1 class="page-header text-2xl md:text-3xl mb-2">
        {heading}
      </h1>
      <p class="text-text dark:text-text-dark">
        {text}
      </p>
    </div>
  </a>
</div>
