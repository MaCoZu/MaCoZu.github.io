---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---

<nav class="h-16 md:h-[2.7rem] top-3 z-50">
  <div class="container mx-auto py-2 md:py-1">
    <div class="grid grid-cols-3 items-center py-3">
      <a href="/" class="flex items-center">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 300 300"
          width="24"
          height="24"
        >
          <path
            class="fill-current text-current"
            d="M273.3 50.5 38 285.9a1.8 1.8 0 0 0 1.3 3h235.3q1.6-.1 1.8-1.7V51.8c0-1.6-2-2.5-3-1.3m-36 199.5H129l108.5-108.4zm-212.7-2.5L260 12c1-1 .6-2.6-.6-3h-1L111 78.2c-7.8 3.6-17 2-23.1-4.2L24.2 10c-.9-1-2.6-.5-2.7.8v235.5c0 1.6 2 2.4 3.2 1.2"
          ></path>
        </svg>
      </a>

      <div class="hidden md:flex justify-end col-start-3">
        <div
          class="flex items-center space-x-8 uppercase text-current text-[16px]"
          style="font-weight: 700 !important"
        >
          <a
            class="text-current page-menu"
            href="/portfolio/"
            style="font-weight: 700 !important">Portfolio</a
          >
          <a
            class="text-current page-menu"
            href="/viz/"
            style="font-weight: 700 !important">Visuals</a
          >
          <a
            class="text-current page-menu"
            href="/notes/"
            style="font-weight: 700 !important">Notes</a
          >
          <a
            class="text-current page-menu"
            href="/certificates/"
            style="font-weight: 700 !important">Certificates</a
          >
          <button
            id="themeToggle"
            aria-label="Toggle theme"
            class="theme-toggle p-1"
          >
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24">
              <path
                class="sun"
                fill="currentColor"
                d="M12 17.5a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zm0 1.5a7 7 0 1 0 0-14 7 7 0 0 0 0 14zm12-7a.8.8 0 0 1-.8.8h-2.4a.8.8 0 0 1 0-1.6h2.4a.8.8 0 0 1 .8.8zM4 12a.8.8 0 0 1-.8.8H.8a.8.8 0 0 1 0-1.6h2.5a.8.8 0 0 1 .8.8zm16.5-8.5a.8.8 0 0 1 0 1l-1.8 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM6.3 17.7a.8.8 0 0 1 0 1l-1.7 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM12 0a.8.8 0 0 1 .8.8v2.5a.8.8 0 0 1-1.6 0V.8A.8.8 0 0 1 12 0zm0 20a.8.8 0 0 1 .8.8v2.4a.8.8 0 0 1-1.6 0v-2.4a.8.8 0 0 1 .8-.8zM3.5 3.5a.8.8 0 0 1 1 0l1.8 1.8a.8.8 0 1 1-1 1L3.5 4.6a.8.8 0 0 1 0-1zm14.2 14.2a.8.8 0 0 1 1 0l1.8 1.7a.8.8 0 0 1-1 1l-1.8-1.7a.8.8 0 0 1 0-1z"
              ></path>
              <path
                class="moon"
                fill="currentColor"
                d="M16.5 6A10.5 10.5 0 0 1 4.7 16.4 8.5 8.5 0 1 0 16.4 4.7l.1 1.3zm-1.7-2a9 9 0 0 1 .2 2 9 9 0 0 1-11 8.8 9.4 9.4 0 0 1-.8-.3c-.4 0-.8.3-.7.7a10 10 0 0 0 .3.8 10 10 0 0 0 9.2 6 10 10 0 0 0 4-19.2 9.7 9.7 0 0 0-.9-.3c-.3-.1-.7.3-.6.7a9 9 0 0 1 .3.8z"
              ></path>
            </svg>
          </button>
        </div>
      </div>

      <div
        class="md:hidden col-start-3 justify-self-end flex items-center gap-10"
      >
        <button
          id="themeToggleMobile"
          aria-label="Toggle theme"
          class="theme-toggle p-2"
        >
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24">
            <path
              class="sun"
              fill="currentColor"
              d="M12 17.5a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zm0 1.5a7 7 0 1 0 0-14 7 7 0 0 0 0 14zm12-7a.8.8 0 0 1-.8.8h-2.4a.8.8 0 0 1 0-1.6h2.4a.8.8 0 0 1 .8.8zM4 12a.8.8 0 0 1-.8.8H.8a.8.8 0 0 1 0-1.6h2.5a.8.8 0 0 1 .8.8zm16.5-8.5a.8.8 0 0 1 0 1l-1.8 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM6.3 17.7a.8.8 0 0 1 0 1l-1.7 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM12 0a.8.8 0 0 1 .8.8v2.5a.8.8 0 0 1-1.6 0V.8A.8.8 0 0 1 12 0zm0 20a.8.8 0 0 1 .8.8v2.4a.8.8 0 0 1-1.6 0v-2.4a.8.8 0 0 1 .8-.8zM3.5 3.5a.8.8 0 0 1 1 0l1.8 1.8a.8.8 0 1 1-1 1L3.5 4.6a.8.8 0 0 1 0-1zm14.2 14.2a.8.8 0 0 1 1 0l1.8 1.7a.8.8 0 0 1-1 1l-1.8-1.7a.8.8 0 0 1 0-1z"
            ></path>
            <path
              class="moon"
              fill="currentColor"
              d="M16.5 6A10.5 10.5 0 0 1 4.7 16.4 8.5 8.5 0 1 0 16.4 4.7l.1 1.3zm-1.7-2a9 9 0 0 1 .2 2 9 9 0 0 1-11 8.8 9.4 9.4 0 0 1-.8-.3c-.4 0-.8.3-.7.7a10 10 0 0 0 .3.8 10 10 0 0 0 9.2 6 10 10 0 0 0 4-19.2 9.7 9.7 0 0 0-.9-.3c-.3-.1-.7.3-.6.7a9 9 0 0 1 .3.8z"
            ></path>
          </svg>
        </button>
        <button
          class="menu-trigger"
          id="mobileMenuButton"
          aria-label="Toggle menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

    <div
      id="mobileSubnavRow"
      class="md:hidden w-full hidden py-3 border-t border-text/20"
    >
      <div
        class="flex flex-wrap justify-between gap-x-2 gap-y-2 uppercase text-current text-[12px]"
      >
        <a
          class="text-current"
          href="/portfolio/"
          style="font-weight: 700 !important">Portfolio</a
        >
        <a class="text-current" href="/viz/" style="font-weight: 700 !important"
          >Visuals</a
        >
        <a
          class="text-current"
          href="/notes/"
          style="font-weight: 700 !important">Notes</a
        >
        <a
          class="text-current"
          href="/certificates/"
          style="font-weight: 700 !important">Certificates</a
        >
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuButton = document.getElementById("mobileMenuButton");
    const mobileSubnavRow = document.getElementById("mobileSubnavRow");

    if (mobileMenuButton && mobileSubnavRow) {
      mobileMenuButton.addEventListener("click", () => {
        mobileMenuButton.classList.toggle("active");
        mobileSubnavRow.classList.toggle("hidden");
      });
    }
  });
</script>

<style>
  #mobileMenuButton,
  #mobileMenuButton span {
    display: inline-block;
    box-sizing: border-box;
  }
  #mobileMenuButton {
    position: relative;
    width: 22px;
    height: 20px;
    background: none;
    border: none;
    appearance: none;
    cursor: pointer;
    padding: 0;
  }
  #mobileMenuButton:focus:not(:focus-visible) {
    outline: none;
  }
  #mobileMenuButton span {
    position: absolute;
    width: 100%;
    height: 2px;
    left: 0;
  }
  #mobileMenuButton span::before,
  #mobileMenuButton span::after {
    content: "";
    position: absolute;
    width: 51%;
    height: 2px;
    background: currentColor;
    transition: 0.4s;
  }
  #mobileMenuButton span::before {
    left: 0;
    border-radius: 2px 0 0 2px;
  }
  #mobileMenuButton span::after {
    right: 0;
    border-radius: 0 2px 2px 0;
  }
  #mobileMenuButton span:nth-of-type(1) {
    top: 1px;
  }
  #mobileMenuButton span:nth-of-type(2) {
    top: 9px;
  }
  #mobileMenuButton span:nth-of-type(3) {
    bottom: 1px;
  }
  #mobileMenuButton.active span:nth-of-type(1)::before {
    transform: translate(2px, 5px) rotate(45deg);
  }
  #mobileMenuButton.active span:nth-of-type(1)::after {
    transform: translate(-2px, 5px) rotate(-45deg);
  }
  #mobileMenuButton.active span:nth-of-type(2)::before {
    transform: translateX(-75%);
    opacity: 0;
  }
  #mobileMenuButton.active span:nth-of-type(2)::after {
    transform: translateX(75%);
    opacity: 0;
  }
  #mobileMenuButton.active span:nth-of-type(3)::before {
    transform: translate(2px, -4px) rotate(-45deg);
  }
  #mobileMenuButton.active span:nth-of-type(3)::after {
    transform: translate(-2px, -4px) rotate(45deg);
  }
</style>
